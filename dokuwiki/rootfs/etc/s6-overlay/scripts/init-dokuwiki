#!/command/with-contenv bashio
# shellcheck shell=bash

bashio::log.info "$(date '+%Y-%m-%d') Starting DokuWiki initialisation..."

# Step 1 — create persistent dirs
mkdir -p \
    /share/dokuwiki/data/pages \
    /share/dokuwiki/data/attic \
    /share/dokuwiki/data/media \
    /share/dokuwiki/data/media_attic \
    /share/dokuwiki/data/media_meta \
    /share/dokuwiki/data/meta \
    /share/dokuwiki/data/locks \
    /share/dokuwiki/data/log \
    /share/dokuwiki/data/index \
    /share/dokuwiki/data/tmp \
    /share/dokuwiki/data/cache \
    /share/dokuwiki/conf \
    /share/dokuwiki/tpl \
    /share/dokuwiki/plugins

# Step 2 — seed on first run
if [ ! -f /share/dokuwiki/conf/dokuwiki.php ]; then
    cp -r /var/www/dokuwiki.dist/conf/. /share/dokuwiki/conf/
fi
if [ ! -d /share/dokuwiki/tpl/dokuwiki ]; then
    cp -r /var/www/dokuwiki.dist/lib/tpl/dokuwiki /share/dokuwiki/tpl/
fi
if [ ! -d /share/dokuwiki/plugins/config ]; then
    cp -r /var/www/dokuwiki.dist/lib/plugins/. /share/dokuwiki/plugins/
fi
if [ ! -d /share/dokuwiki/data/media/wiki ]; then
    cp -r /var/www/dokuwiki.dist/data/media/wiki /share/dokuwiki/data/media/
fi

# Step 3 — PHP options from add-on config
UPLOAD_LIMIT=$(bashio::config 'php_upload_limit')
MEMORY_LIMIT=$(bashio::config 'php_memory_limit')
TIMEZONE=$(bashio::config 'php_timezone')
cat > /etc/php83/php-fpm.d/dokuwiki-options.conf << EOF
[www]
php_admin_value[upload_max_filesize] = ${UPLOAD_LIMIT}
php_admin_value[post_max_size] = ${UPLOAD_LIMIT}
php_admin_value[memory_limit] = ${MEMORY_LIMIT}
php_admin_value[date.timezone] = ${TIMEZONE}
EOF

# Step 5 — remove install.php if setup is complete (users.auth.php contains a real user entry)
# NOTE: conf/dokuwiki.php is NOT a reliable indicator — it is seeded from dist on first run.
# A non-comment line in users.auth.php means install.php has been completed.
if grep -qm1 '^[^#[:space:]]' /share/dokuwiki/conf/users.auth.php 2>/dev/null \
        && [ -f /var/www/dokuwiki/install.php ]; then
    bashio::log.info "$(date '+%Y-%m-%d') Removing install.php (setup already complete)"
    rm /var/www/dokuwiki/install.php
fi

# Step 6 — symlink persistent storage into webroot
rm -rf /var/www/dokuwiki/data \
       /var/www/dokuwiki/conf \
       /var/www/dokuwiki/lib/tpl \
       /var/www/dokuwiki/lib/plugins
ln -sf /share/dokuwiki/data    /var/www/dokuwiki/data
ln -sf /share/dokuwiki/conf    /var/www/dokuwiki/conf
ln -sf /share/dokuwiki/tpl     /var/www/dokuwiki/lib/tpl
ln -sf /share/dokuwiki/plugins /var/www/dokuwiki/lib/plugins

# Step 7 — ownership
chown -R nobody:nobody /share/dokuwiki

# First-run prompt — shown until install.php is completed
if ! grep -qm1 '^[^#[:space:]]' /share/dokuwiki/conf/users.auth.php 2>/dev/null; then
    bashio::log.warning "$(date '+%Y-%m-%d') Setup not complete — open the add-on web UI to complete setup"
fi

bashio::log.info "$(date '+%Y-%m-%d') DokuWiki initialisation complete"
